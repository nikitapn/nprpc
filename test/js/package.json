{
  "name": "nprpc_js_test",
  "version": "1.0.0",
  "description": "NPRPC JS Test",
  "license": "ISC",
  "author": "",
  "type": "commonjs",
  "main": "index.js",
  "scripts": {
    "build": "tsc --project tsconfig.json && webpack --config webpack.browser.config.js",
    "test": "mocha",
    "test:basic": "npm run build && mocha dist/test/basic.test.js",
    "test:webtransport-browser": "npm run build && mocha --grep \"^WebTransport Browser Transport\" --timeout 120000",
    "test:watch": "npm run build && mocha --watch",
    "test:debug": "npm run build && mocha dist/test/**/*.js --timeout 60000 --grep",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "nprpc": "file:../../nprpc_js/dist",
    "ws": "^8.13.0"
  },
  "devDependencies": {
    "@types/chai": "^4.3.5",
    "@types/mocha": "^10.0.1",
    "@types/node": "^20.5.0",
    "@types/ws": "^8.5.5",
    "chai": "^4.3.7",
    "mocha": "^10.2.0",
    "playwright-core": "^1.58.2",
    "ts-loader": "^9.5.2",
    "typescript": "^5.8.3"
    ,"webpack": "^5.99.9"
    ,"webpack-cli": "^6.0.1"
  }
}
