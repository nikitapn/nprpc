{
    "name": "@nprpc/adapter-sveltekit",
    "version": "1.0.0",
    "description": "SvelteKit adapter for NPRPC - serves SSR via shared memory IPC",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/nikitapn/nprpc.git"
    },
    "type": "module",
    "main": "index.js",
    "types": "index.d.ts",
    "exports": {
        ".": {
            "types": "./index.d.ts",
            "import": "./index.js"
        },
        "./handler": {
            "types": "./handler.d.ts",
            "import": "./handler.js"
        }
    },
    "files": [
        "index.js",
        "index.d.ts",
        "handler.js",
        "handler.d.ts",
        "files/"
    ],
    "scripts": {
        "test": "echo \"No tests yet\""
    },
    "keywords": [
        "svelte",
        "sveltekit",
        "adapter",
        "nprpc",
        "ssr",
        "shared-memory",
        "ipc"
    ],
    "author": "nikitapnn1@gmail.com",
    "license": "MIT",
    "peerDependencies": {
        "@sveltejs/kit": "^2.0.0"
    },
    "dependencies": {
        "@nprpc/node_addon": "^1.0.0",
        "@rollup/plugin-commonjs": "^29.0.0",
        "@rollup/plugin-json": "^6.1.0",
        "@rollup/plugin-node-resolve": "^16.0.0",
        "rollup": "^4.59.0"
    },
    "devDependencies": {
        "@sveltejs/kit": "^2.0.0",
        "@types/node": "^20.10.0",
        "typescript": "^5.3.0"
    }
}
