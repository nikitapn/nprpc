{
  "name": "@nprpc/devtools",
  "version": "1.0.0",
  "description": "Chrome DevTools extension for inspecting NPRPC calls and streams",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nikitapn/nprpc.git"
  },
  "type": "module",
  "files": [
    "dist/",
    "README.md"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./tsconfig.app.json && tsc -p tsconfig.node.json",
    "clean": "rm -rf dist",
    "prepack": "npm run build"
  },
  "keywords": [
    "nprpc",
    "devtools",
    "chrome-extension",
    "rpc",
    "streaming",
    "debugging"
  ],
  "author": "nikitapnn1@gmail.com",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/nikitapn/nprpc/issues"
  },
  "homepage": "https://github.com/nikitapn/nprpc/tree/main/nprpc_devtools",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^6.2.1",
    "@tsconfig/svelte": "^5.0.6",
    "@types/node": "^24.10.1",
    "chrome-types": "^0.1.416",
    "svelte": "^5.45.2",
    "svelte-check": "^4.3.4",
    "typescript": "~5.9.3",
    "vite": "^8.0.0-beta.13"
  },
  "overrides": {
    "vite": "^8.0.0-beta.13"
  }
}
